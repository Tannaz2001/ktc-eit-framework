# KTC Dashboard Configuration (.env.example)
# Copy this file to .env and customize for your environment

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# ============================================================================
# STREAMLIT
# ============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# ============================================================================
# RUN LOCKING (Prevents concurrent benchmarks)
# ============================================================================
# Lock timeout in seconds (default: 2 hours)
RUN_LOCK_TIMEOUT=7200

# ============================================================================
# CACHE MANAGEMENT (Jacobian matrices & results)
# ============================================================================
# Enable cache validation before use (prevents stale results)
CACHE_VALIDATION=true

# ============================================================================
# DISK MANAGEMENT
# ============================================================================
# Maximum disk usage percentage before warnings (0-100)
MAX_DISK_USAGE_PCT=85

# ============================================================================
# OPTIONAL: Custom Paths (if different from defaults)
# ============================================================================
# EVALUATION_DATA_DIR=EvaluationData
# OUTPUTS_DIR=outputs
# CODES_MATLAB_DIR=Codes_Matlab
