# Note: EvaluationData/ is intentionally tracked (584 KB — real KTC 2023
# voltage measurements, not images, so it's small enough to ship in git).

# MATLAB generated files
Codes_Matlab/Output/
*.asv

# Machine-local config overrides (never commit these)
configs/local_*.yaml

# Generated outputs — all excluded except the pre-computed demo run
outputs/
outputs_smoke/
scores.json
# Ship the canonical demo run so local-venv and docker-compose users see data on first boot
!outputs/run_20260719_191247/
!outputs/latest.txt
reports/
configs/runtime_*.yaml

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Large model weights outside abc1 (abc1/ultimate_cnn1.h5 is only 13 MB — committed)
src/ktc_framework/models/

# Generated output folders inside abc1
external_methods/abc1/Outputs/
external_methods/abc1/test_output/
